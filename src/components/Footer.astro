<div class="pb-20"></div>

<!-- Back to top -->
<button
  id="back-to-top"
  class="fixed bottom-8 right-8 z-50 flex h-10 w-10 items-center justify-center rounded-lg border border-border bg-surface opacity-0 transition-all duration-300 hover:border-accent hover:shadow-[0_0_12px_var(--color-accent-glow)] pointer-events-none"
  aria-label="回到頂部"
>
  <svg class="h-5 w-5 text-text-muted" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
    <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 15.75l7.5-7.5 7.5 7.5" />
  </svg>
</button>

<script>
  const btn = document.getElementById('back-to-top');
  window.addEventListener('scroll', () => {
    if (window.scrollY > 500) {
      btn?.classList.remove('opacity-0', 'pointer-events-none');
      btn?.classList.add('opacity-100');
    } else {
      btn?.classList.add('opacity-0', 'pointer-events-none');
      btn?.classList.remove('opacity-100');
    }
  });
  btn?.addEventListener('click', () => {
    window.scrollTo({ top: 0, behavior: 'smooth' });
  });
</script>

---
import { profile } from '../data/resume';
---

<section id="contact" class="mx-auto max-w-[1200px] px-6 py-20 md:px-12">
  <div class="section-label mb-12 font-mono text-xs uppercase tracking-[3px] text-accent" data-i18n="section.contact"></div>

  <div class="fade-up">
    <h2 class="mb-6 font-mono text-3xl font-bold" data-i18n="contact.title"></h2>
    <p class="mb-10 text-text-muted" data-i18n="contact.desc"></p>

    <div class="flex flex-col gap-6 sm:flex-row sm:gap-12">
      <a href={`mailto:${profile.email}`} class="group flex items-center gap-3 transition-colors duration-300">
        <div class="flex h-10 w-10 items-center justify-center rounded-lg border border-border bg-surface transition-all duration-300 group-hover:border-accent group-hover:shadow-[0_0_12px_var(--color-accent-glow)]">
          <svg class="h-5 w-5 text-text-muted group-hover:text-accent transition-colors duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
          </svg>
        </div>
        <div>
          <div class="font-mono text-xs text-text-dim" data-i18n="contact.email"></div>
          <div class="text-sm text-text-muted group-hover:text-accent transition-colors duration-300">{profile.email}</div>
        </div>
      </a>

      <a href={`tel:${profile.phone.replace(/-/g, '')}`} class="group flex items-center gap-3 transition-colors duration-300">
        <div class="flex h-10 w-10 items-center justify-center rounded-lg border border-border bg-surface transition-all duration-300 group-hover:border-accent group-hover:shadow-[0_0_12px_var(--color-accent-glow)]">
          <svg class="h-5 w-5 text-text-muted group-hover:text-accent transition-colors duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
          </svg>
        </div>
        <div>
          <div class="font-mono text-xs text-text-dim" data-i18n="contact.phone"></div>
          <div class="text-sm text-text-muted group-hover:text-accent transition-colors duration-300">{profile.phone}</div>
        </div>
      </a>

      <div class="flex items-center gap-3">
        <div class="flex h-10 w-10 items-center justify-center rounded-lg border border-border bg-surface">
          <svg class="h-5 w-5 text-text-muted" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
          </svg>
        </div>
        <div>
          <div class="font-mono text-xs text-text-dim" data-i18n="contact.location"></div>
          <div class="text-sm text-text-muted" data-i18n="contact.locationValue"></div>
        </div>
      </div>

      <a href={profile.github} target="_blank" rel="noopener noreferrer" class="group flex items-center gap-3 transition-colors duration-300">
        <div class="flex h-10 w-10 items-center justify-center rounded-lg border border-border bg-surface transition-all duration-300 group-hover:border-accent group-hover:shadow-[0_0_12px_var(--color-accent-glow)]">
          <svg class="h-5 w-5 text-text-muted group-hover:text-accent transition-colors duration-300" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/>
          </svg>
        </div>
        <div>
          <div class="font-mono text-xs text-text-dim" data-i18n="contact.github"></div>
          <div class="text-sm text-text-muted group-hover:text-accent transition-colors duration-300">weihung0831</div>
        </div>
      </a>
    </div>
  </div>
</section>

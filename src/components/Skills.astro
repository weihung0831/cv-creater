---
import { skills } from '../data/resume';
---

<section id="skills" class="mx-auto max-w-[1200px] px-6 py-20 md:px-12">
  <div class="section-label mb-12 font-mono text-xs uppercase tracking-[3px] text-accent" data-i18n="section.skills"></div>
  <div class="grid gap-x-12 gap-y-6 sm:grid-cols-2 lg:grid-cols-3">
    {skills.map((skill) => (
      <div class="skill-item flex flex-col gap-2">
        <div class="flex items-center justify-between">
          <span class="font-mono text-[13px] text-text">{skill.name}</span>
          <span class="font-mono text-[11px] text-text-dim">{skill.percentage}%</span>
        </div>
        <div class="h-1 overflow-hidden rounded-full bg-surface-2">
          <div
            class="skill-bar h-full rounded-full bg-accent shadow-[0_0_8px_var(--color-accent-glow)]"
            data-width={`${skill.percentage}%`}
            style="width: 0%"
          ></div>
        </div>
      </div>
    ))}
  </div>
</section>

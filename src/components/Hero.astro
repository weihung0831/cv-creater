---
---

<section id="about" class="relative flex min-h-screen flex-col justify-center overflow-hidden px-6 md:px-12">
  <canvas id="particles-canvas" class="absolute inset-0 z-0"></canvas>

  <div
    class="pointer-events-none absolute left-1/2 top-1/2 h-[600px] w-[600px] -translate-x-1/2 -translate-y-1/2 rounded-full"
    style="background: radial-gradient(circle, var(--color-accent-glow) 0%, transparent 70%)"
  ></div>

  <div class="relative z-10 mx-auto max-w-[1200px]">
    <div class="mb-4 font-mono text-sm tracking-[2px] text-accent">
      <span id="typewriter"></span><span class="animate-blink inline-block h-[18px] w-[2px] bg-accent align-text-bottom"></span>
    </div>

    <h1 class="hero-title mb-4 bg-gradient-to-br from-text to-text-muted bg-clip-text font-mono text-[clamp(48px,8vw,96px)] font-bold leading-[1.05] text-transparent opacity-0" data-i18n="hero.name"></h1>

    <p class="hero-subtitle mb-8 text-[clamp(20px,3vw,32px)] font-light text-text-muted opacity-0">
      <span data-i18n="hero.title"></span> / <span class="font-medium text-accent" data-i18n="hero.subtitle"></span>
    </p>

    <p class="hero-desc mb-10 max-w-[560px] text-base leading-relaxed text-text-dim opacity-0" data-i18n="hero.summary"></p>

    <a
      href="#experience"
      class="hero-cta inline-flex items-center gap-2 rounded-[4px] bg-accent px-7 py-3 font-mono text-sm text-bg opacity-0 shadow-[0_0_20px_var(--color-accent-glow)] transition-all duration-300 hover:-translate-y-0.5 hover:shadow-[0_0_40px_rgba(6,182,212,0.3)]"
      data-i18n="hero.cta"
    ></a>
  </div>

  <div class="absolute bottom-10 left-1/2 z-10 flex -translate-x-1/2 flex-col items-center gap-2">
    <span class="font-mono text-[11px] uppercase tracking-[2px] text-text-dim" data-i18n="hero.scroll"></span>
    <div class="animate-scroll-line h-10 w-[1px] bg-gradient-to-b from-accent to-transparent"></div>
  </div>
</section>

<style>
  @keyframes blink { 50% { opacity: 0; } }
  .animate-blink { animation: blink 1s step-end infinite; }
  @keyframes scrollLine { 0%, 100% { opacity: 0.3; } 50% { opacity: 1; } }
  .animate-scroll-line { animation: scrollLine 2s ease-in-out infinite; }
</style>

<script>
  import { initParticles } from '../scripts/particles';
  import { initTypewriter } from '../scripts/typewriter';

  const canvas = document.getElementById('particles-canvas') as HTMLCanvasElement;
  if (canvas) initParticles(canvas);

  const el = document.getElementById('typewriter');
  if (el) initTypewriter(el, '$ whoami');
</script>
